NODE_ENV=development
PORT=8080
APP_ORIGIN=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://backtoyou:backtoyou@127.0.0.1:27017/backtoyou?authSource=admin
MONGODB_DB=backtoyou

# Auth
JWT_SECRET=replace-me
JWT_EXPIRES_IN=7d

# Admin seed (local convenience)
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin12345
RESET_ADMIN_PASSWORD=0
ALLOW_ADMIN_EMAIL_CHANGE=0

# Admin login requires a shared secret (entered on the admin login page).
ADMIN_LOGIN_SECRET=replace-me

# One-admin system:
# - There can only be one ADMIN user, enforced via a unique DB constraint.
# - The primary admin is the user with adminSingleton=true (set by seed).

# ML service (Python)
ML_SERVICE_URL=http://localhost:8090
# Optional shared secret for backend -> ML service calls (sent as header `x-ml-token`).
ML_SERVICE_TOKEN=

# Optional: force local scoring in the Node backend (no Python service required).
# Values: "service" (default) or "local"
ML_MODE=service

# Matching thresholds (confidence label only; never auto-return)
HIGH_CONFIDENCE_THRESHOLD=0.9

# Uploads
PUBLIC_BASE_URL=http://localhost:8080
UPLOAD_DIR=uploads

# Cloudinary (preferred; optional). If unset, uses local upload storage.
CLOUDINARY_URL=

# Email (optional; if unset, emails are logged)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="BackToYou <no-reply@backtoyou.local>"
